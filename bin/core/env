#!/usr/bin/env bash

if [[ -z $STOW_FOLDERS ]]; then
	STOW_FOLDERS="bin,nvim,bash,tmux"
	if [[ "$(uname -s)" == "Darwin" ]]; then
		STOW_FOLDERS="$STOW_FOLDERS,macos"
	else
		STOW_FOLDERS="$STOW_FOLDERS,omarchy"
	fi
fi

if [[ -z $DOTFILES ]]; then
	DOTFILES=$HOME/.dotfiles
fi

STOW_FOLDERS=$STOW_FOLDERS DOTFILES=$DOTFILES
