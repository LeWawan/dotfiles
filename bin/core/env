#!/usr/bin/env bash

if [[ -z $STOW_FOLDERS ]]; then
	STOW_FOLDERS="bin,nvim"
	if [[ "$(uname -s)" == "Darwin" ]]; then
		STOW_FOLDERS="$STOW_FOLDERS,zsh,tmux,aerospace,sketchybar"
	else
		STOW_FOLDERS="$STOW_FOLDERS,bash,tmux,omarchy"
	fi
fi

if [[ -z $DOTFILES ]]; then
	DOTFILES=$HOME/.dotfiles
fi

STOW_FOLDERS=$STOW_FOLDERS DOTFILES=$DOTFILES
