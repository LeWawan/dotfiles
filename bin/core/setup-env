#!/usr/bin/env bash
set -eo pipefail

source ./bin/core/env

pushd "$DOTFILES" > /dev/null
for folder in $(echo "$STOW_FOLDERS" | sed "s/,/ /g"); do
	echo "[link] stow $folder folder"
	stow -D "$folder"
	stow --adopt "$folder"
done
# Stow system-level configs (targeting / instead of $HOME)
if [[ "$(uname -s)" == "Linux" ]]; then
	for folder in coolercontrol; do
		if [[ -d "$folder" ]]; then
			echo "[link] stow $folder folder (system: /etc)"
			sudo stow -t / -D "$folder"
			sudo stow -t / --adopt "$folder"
		fi
	done
fi
popd > /dev/null
