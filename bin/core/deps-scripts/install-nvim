#!/usr/bin/env bash
set -euo pipefail

echo "Installing Neovim..."

if [[ "$(uname)" == "Linux" ]] && command -v pacman &>/dev/null; then
  echo "Using pacman..."
  sudo pacman -S --noconfirm --needed neovim
else
  # Build from source on other platforms
  NVIM_VERSION="v0.11.1"
  NVIM_DIR="$HOME/personal/neovim"

  echo "Building Neovim $NVIM_VERSION from source..."
  if [[ -d "$NVIM_DIR" ]]; then
    rm -rf "$NVIM_DIR"
  fi

  git clone -b "$NVIM_VERSION" https://github.com/neovim/neovim.git "$NVIM_DIR"

  cd "$NVIM_DIR"
  make CMAKE_BUILD_TYPE=RelWithDebInfo
  sudo make install
fi

nvim --version | head -1

echo "Neovim installed."
