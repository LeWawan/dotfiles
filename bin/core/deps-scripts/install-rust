#!/usr/bin/env bash
set -euo pipefail

echo "🚀 Installing Rust env"

if command -v mise &>/dev/null; then
  echo "Using mise..."
  mise use --global rust@latest
  source "$HOME/.cargo/env"
  rustc --version
  echo "✅ Rust installé avec mise."
  exit 0
else
  echo "Neither omarchy-install-dev-env nor mise found."
  echo "Install mise first: https://mise.jdx.dev"
fi

rustc --version

echo "✅ Rust installé avec rustup."
