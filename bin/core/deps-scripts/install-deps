#!/usr/bin/env bash
set -euo pipefail

BASE_DIR=$(pwd)

echo "[install] Installing system dependencies..."
if [[ "$(uname)" == "Linux" ]]; then
  if command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm --needed base-devel ripgrep fd unzip stow fortune-mod cowsay direnv bash-completion
  elif command -v apt-get &>/dev/null; then
    sudo apt-get update
    sudo apt-get install -y curl wget python3 python3-pip ripgrep fd-find unzip stow fortune cowsay gcc make cmake libssl-dev direnv bash-completion
  elif command -v dnf &>/dev/null; then
    sudo dnf install -y curl wget python3 python3-pip ripgrep fd-find unzip stow fortune cowsay gcc make cmake openssl-devel direnv bash-completion
  else
    echo "Package manager not supported. Please install dependencies manually."
    exit 1
  fi
elif [[ "$(uname)" == "Darwin" ]]; then
  if command -v brew &>/dev/null; then
    brew update
    brew install curl wget ripgrep unzip stow fortune cowsay fd cmake openssl direnv bash-completion
  else
    echo "Homebrew not found. Please install it manually."
    exit 1
  fi
else
  echo "Unsupported OS: $(uname)"
  exit 1
fi
echo "[install] System dependencies installed."
