#!/usr/bin/env bash
source "$(dirname "$0")/_helpers.sh"

log_info "Installing system dependencies..."

if is_arch; then
  install_pkg base-devel ripgrep fd unzip stow fortune-mod cowsay direnv bash-completion eza
elif [[ "$_PKG_MGR" == "apt" ]]; then
  sudo apt-get update
  install_pkg curl wget python3 python3-pip ripgrep fd-find unzip stow fortune cowsay gcc make cmake libssl-dev direnv bash-completion eza
elif [[ "$_PKG_MGR" == "brew" ]]; then
  brew update
  install_pkg curl wget ripgrep unzip stow fortune cowsay fd cmake openssl direnv bash-completion eza
else
  log_error "Unsupported platform."
  exit 1
fi

log_info "System dependencies installed."
