#!/usr/bin/env bash
set -euo pipefail

echo "Installing Node.js environment..."

if command -v omarchy-install-dev-env &>/dev/null; then
  echo "Using omarchy-install-dev-env..."
  omarchy-install-dev-env node
elif command -v mise &>/dev/null; then
  echo "Using mise..."
  mise use --global node@latest
  mise use --global pnpm@latest
else
  echo "Neither omarchy-install-dev-env nor mise found."
  echo "Install mise first: https://mise.jdx.dev"
  exit 1
fi

node --version
pnpm --version

# Install @antfu/ni globally
npm i -g @antfu/ni

echo "Node.js environment installed."
