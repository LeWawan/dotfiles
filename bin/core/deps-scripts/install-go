#!/usr/bin/env bash
set -euo pipefail

echo "Installing Go..."

if command -v omarchy-install-dev-env &>/dev/null; then
  echo "Using omarchy-install-dev-env..."
  omarchy-install-dev-env go
elif command -v mise &>/dev/null; then
  echo "Using mise..."
  mise use --global go@latest
else
  echo "Neither omarchy-install-dev-env nor mise found."
  echo "Install mise first: https://mise.jdx.dev"
  exit 1
fi

# Activate mise in current shell if needed
if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
fi

go version

echo "Go installed."
