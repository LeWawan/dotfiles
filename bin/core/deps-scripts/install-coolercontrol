#!/usr/bin/env bash
source "$(dirname "$0")/_helpers.sh"

log_info "Installing CoolerControl..."

if command -v coolercontrol &>/dev/null; then
  log_info "CoolerControl is already installed."
else
  if ! is_arch; then
    log_error "CoolerControl install only supported on Arch (pacman)."
    log_error "See: https://gitlab.com/coolercontrol/coolercontrol"
    exit 1
  fi
  install_pkg coolercontrol
fi

if command -v cctv &>/dev/null; then
  log_info "cctv is already installed."
else
  require_cmd curl
  require_cmd jq
  TAG=$(curl -sL https://gitlab.com/api/v4/projects/69657520/releases/permalink/latest | jq -r .tag_name)
  curl -L "https://gitlab.com/coolercontrol/cctv/-/archive/${TAG}/cctv-${TAG}.tar.gz" | \
      tar -xzf - --strip-components=2 -C /tmp "cctv-${TAG}/dist/cctv@.service"
  sudo install -Dm 644 /tmp/cctv@.service -t /etc/systemd/system/
  sudo systemctl daemon-reload
  sudo systemctl enable --now "cctv@$USER.service"
fi

log_info "Enabling CoolerControl service..."
sudo systemctl enable --now coolercontrold.service

require_cmd secret-tool
if secret-tool lookup service cctv type password &>/dev/null; then
  log_info "CCTV daemon password already stored in keyring."
else
  log_info "Storing CCTV daemon password in keyring..."
  echo "Enter CCTV daemon password:"
  secret-tool store --label="CCTV daemon password" service cctv type password < /dev/tty
  log_info "CCTV daemon password stored in keyring."
fi

log_info "CoolerControl installed and service enabled."
