#!/usr/bin/env bash
set -euo pipefail

echo "Installing Lua environment..."

if command -v omarchy-install-dev-env &>/dev/null; then
  echo "Using omarchy-install-dev-env..."
  omarchy-install-dev-env lua
elif command -v mise &>/dev/null; then
  echo "Using mise..."
  mise use --global lua@latest
else
  echo "Neither omarchy-install-dev-env nor mise found."
  echo "Install mise first: https://mise.jdx.dev"
  exit 1
fi

lua -v

echo "Lua environment installed."
