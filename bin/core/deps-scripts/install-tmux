#!/usr/bin/env bash
source "$(dirname "$0")/_helpers.sh"

log_info "Installing tmux..."

if command -v tmux &>/dev/null; then
  log_info "tmux is already installed. Skipping."
else
  install_pkg tmux
  log_info "tmux installed."
fi

if [[ ! -d "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/plugins/tpm" ]]; then
  log_info "Installing tmux plugin manager (tpm)..."
  git clone https://github.com/tmux-plugins/tpm ~/.config/tmux/plugins/tpm
  log_info "tpm installed. Open tmux and press 'prefix + I' to install plugins."
else
  log_info "tpm is already installed. Skipping."
fi
