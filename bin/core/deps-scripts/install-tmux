#!/usr/bin/env bash
set -euo pipefail

echo "Installing tmux..."

if command -v tmux &> /dev/null; then
    echo "tmux is already installed. Skipping."
else
    if command -v brew &> /dev/null; then
        echo "Homebrew is installed. Using Homebrew to install tmux."
        brew install tmux
    elif command -v apt-get &> /dev/null; then
        echo "apt-get is available. Using apt-get to install tmux."
        sudo apt-get update
        sudo apt-get install -y tmux
    elif command -v pacman &> /dev/null; then
        echo "pacman is available. Using pacman to install tmux."
        sudo pacman -S --noconfirm tmux
    else
        echo "No supported package manager found. Please install tmux manually."
        exit 1
    fi

    echo "tmux installed successfully."
fi

if [[ ! -d "$XDG_CONFIG_HOME/tmux/plugins/tpm" ]]; then
    echo "Installing tmux plugin manager (tpm)..."
    git clone https://github.com/tmux-plugins/tpm ~/.config/tmux/plugins/tpm

    echo "tmux plugin manager (tpm) installed successfully."

    echo "To install tmux plugins, open tmux and press 'prefix + I' (default prefix is 'Ctrl + b') to fetch the plugins specified in your .tmux.conf file."
else
    echo "tmux plugin manager (tpm) is already installed. Skipping."
fi
